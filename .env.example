# Reference file — not auto-loaded. Export these in your shell or CI
# environment before running gandalf-grader.

# Required: API key for the LLM provider used by the judge agent
LLM_API_KEY=

# Optional: base URL for the LLM API (e.g. for OpenRouter, local models)
LLM_BASE_URL=

# Optional: fallback path to judge guidance file (if not set in verifier TOML)
VERIFIER_JUDGE_GUIDANCE_PATH=
